{
  "name": "@middle-monitor/sdk",
  "version": "0.1.3",
  "description": "TypeScript SDK for Middle-Monitor error reporting with OpenTelemetry",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./expressMiddleware": {
      "types": "./dist/expressMiddleware.d.ts",
      "default": "./dist/expressMiddleware.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/middle-monitor/sdk-typescript.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "monitoring",
    "error-tracking",
    "middle-monitor",
    "opentelemetry",
    "observability"
  ],
  "author": "Middle-Monitor",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/api-logs": "^0.49.1",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.49.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.49.1",
    "@opentelemetry/instrumentation": "^0.49.1",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.49.1",
    "@opentelemetry/semantic-conventions": "^1.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ]
}
